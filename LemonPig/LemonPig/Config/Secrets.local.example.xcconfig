// TEMPLATE — copy this file to Secrets.local.xcconfig (which is git-ignored)
// and fill in your values. Leave Secrets.local.xcconfig absent or empty to
// keep the bring-your-own-key flow.
//
// ⚠️  xcconfig parses a literal "//" as the start of a comment, so the "//" in
//     an https:// URL MUST be broken with the empty $() expansion shown below.
//     Change only the host and the token; keep the "https:/$()/" prefix intact.

LPIdentifyProxyURL = https:/$()/lemonpig-identify.YOUR-SUBDOMAIN.workers.dev/identify
LPIdentifyAppToken = your-app-token-here
