// Base build config for the LemonPig app target.
//
// Defaults below keep the app in bring-your-own-key mode: each user enters
// their own Claude API key on the camera screen. To route identification
// through your Cloudflare Worker proxy instead (so the app ships no key),
// copy Secrets.local.example.xcconfig to Secrets.local.xcconfig and fill it in.
//
// These two values flow into Info.plist via $(LPIdentifyProxyURL) /
// $(LPIdentifyAppToken), which FruitIdentifier reads at launch.

LPIdentifyProxyURL =
LPIdentifyAppToken =

// Optional, git-ignored override. The "?" makes this a no-op when the file is
// absent (e.g. a fresh clone), so the committed defaults above still stand.
#include? "Secrets.local.xcconfig"
